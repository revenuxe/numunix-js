NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Used to build absolute URLs for metadata, sitemap.xml and JSON-LD. Set this to
# the production domain before deploying.
NEXT_PUBLIC_SITE_URL=https://numunix.com

# Optional. If set, /api/revalidate requires this value in the
# x-revalidate-secret header. Leave unset in development.
REVALIDATE_SECRET=

# Resend (https://resend.com) — sends an email to numunix@gmail.com for every
# lead submitted through the contact/booking forms. Leave unset to disable
# email notifications without breaking form submissions.
RESEND_API_KEY=
# Sender shown on the notification email. "onboarding@resend.dev" needs no
# setup but reliably lands in spam. For real delivery, verify a SENDING
# subdomain (not the root numunix.com, which already has its own mailbox MX
# records) in Resend, e.g. mail.numunix.com, then point this at it:
RESEND_FROM_EMAIL=Numunix Website <onboarding@resend.dev>
